@using Gambl.Models
@model CourseInfo


        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        <link rel="stylesheet" href="~/css/course.css">
   
    <div class="container">
        <div id="detail" class="content-container">
            <div class="text-container"> 
                <h2>@Model.CourseName</h2> 
                <h5>@Model.CourseExplain</h5> 
                <button class="btn btn-primary btn-lg  "> Sign Up Now</button>
            </div> 
            <div class="image-container"> 
                <img src="@Url.Action("GetCourseImage", new { id = Model.CourseId })" alt="Course Image" /> 
            </div> 
        </div>
            
        <div class="curriculum">
                <h5>Curriculum</h5>
                @foreach(var lesson in Model.Lessons)
                {
                    <button class="collapsible">@lesson.LessonName</button>
                    <div class="dropdown-content">
                        <ul class="list">
                            @foreach(var content in lesson.content)
                            {
                                <li>@content.ContentName</li>
                            }
                        </ul>
                    </div>
                }
        </div>
        
        <div class="instructor" class="text-center">
            <h5>Instructor</h5>
            <img src="@Url.Action("GetInstructorImage", new { id = Model.CourseId })" alt="Instructor Image"  class="rounded-circle" style="width:190px;height:180px;" /> 
            <p><a style="text-decoration: none; color: black;" asp-controller="Home" asp-action="Instructor" asp-route-id="@Model.InstructorId">@Model.CourseInstructor</a></p>
            
        </div>

    </div>
    <script src="~/js/couse.js"></script>
    }

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GAMBL</title>
 <link rel="stylesheet" href="~/css/layout.css">
</head>
<body>
  <header class="site-header">
    
    <div class="logo-section">
      <a asp-controller="Home" asp-action="Index">
      <img src="/img/file.png" alt="Logo" class="logo">
      </a>
    </div>

    
    <div class="site-name">
      GAMBL
    </div>

    
    <div class="link-section">
    @if (User?.Identity?.IsAuthenticated==true)
    {
      <a asp-controller="Home" asp-action="MyAccount" class="link">My Learning</a>
        <a asp-controller="Login" asp-action="Logout" class="link">Logout</a>
        
        
    }
    else
    {
        <a asp-controller="Login" asp-action="Admission" class="link">Log in</a>
        <span class="divider">|</span>
        <a asp-controller="Login" asp-action="SignUp" class="link">Sign Up</a>
    }
</div>
    
  </header>
  <div class="content">
  @RenderBody()
  </div>
   <footer class="site-footer">
    <div class="footer-content">
      <div class="footer-section">
        <p>&copy; 2024 Gambl. All rights reserved.</p>
      </div>
      <div class="footer-section social-links">
        <a href="#" class="social-link">Facebook</a>
        <a href="#" class="social-link">Twitter</a>
        <a href="#" class="social-link">Instagram</a>
      </div>
      <div class="footer-section">
        <a href="/contact" class="footer-link">Contact us</a>
        <a href="/privacy" class="footer-link">Privacy Policy</a>
        <a href="/terms" class="footer-link">Terms of Use</a>
      </div>
    </div>
  </footer>
  @section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
  }
</body>
</html>
